# WSL defaults. Copy to .env and adjust paths for your machine.
QWEN_MODEL_PATH=/home/ardam/projects/CerberusVision/models/Qwen-2.5-7B-Instruct-INT4
# Arc 140V WSL profile: 7B runs on GPU. Keep the 14B model as an optional CPU profile.
OPENVINO_DEVICE=GPU
OPENVINO_CACHE_DIR=/home/ardam/projects/CerberusVision/.openvino_cache
OPENVINO_KV_CACHE_PRECISION=u8
SSE_TIMEOUT_SECONDS=1800

# Optional, risk-based short audit. Leave empty to keep all data local.
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_REVIEW_MODE=risk
DEEPSEEK_RISK_THRESHOLD=30
DEEPSEEK_MAX_OCR_EXCERPT_CHARS=2500

DOCUMENT_SEARCH_PROVIDER=auto
BRAVE_SEARCH_API_KEY=
GOOGLE_SEARCH_API_KEY=
GOOGLE_SEARCH_ENGINE_ID=
DOCUMENT_SEARCH_OUTPUT_DIR=/home/ardam/projects/CerberusVision/veriler/discovered
DOCUMENT_SEARCH_MAX_FILE_MB=20
DOCUMENT_SEARCH_MAX_RESULTS=20
DOCUMENT_SEARCH_MIN_LOCAL_SCORE=60
DOCUMENT_SEARCH_MAX_REVIEW_CHARS=3500
DOCUMENT_SEARCH_MAX_OCR_PAGES=2
